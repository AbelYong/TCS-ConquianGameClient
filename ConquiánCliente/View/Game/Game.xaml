<Window x:Class="ConquiánCliente.View.Game.Game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Partida"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="Black"
        MouseMove="WindowMouseMove">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <DataTemplate x:Key="CardTemplate">
            <Border Width="144" Height="216" Margin="-20"
                    MouseLeftButtonDown="PlayerCardMouseLeftButtonDown"
                    MouseMove="PlayerCardMouseMove"
                    MouseLeftButtonUp="PlayerCardMouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="4"/>
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="Yellow"/>
                                <Setter Property="BorderThickness" Value="4"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBeingDragged}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Image Source="{Binding ImagePath}" ToolTip="{Binding Id}"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="OpponentCardTemplate">
            <Image Source="/Resources/Assets/reverso.png" 
                   Width="144" Height="216" 
                   Margin="5, 5, -114, 5"/>
        </DataTemplate>

        <DataTemplate x:Key="MeldedCardTemplate">
            <Border Width="100" Height="150" Margin="-35, 0, -35, 0">
                <Image Source="{Binding ImagePath}" ToolTip="{Binding Id}"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MeldTemplate">
            <ItemsControl 
                ItemsSource="{Binding Cards}"
                ItemTemplate="{StaticResource MeldedCardTemplate}"
                Margin="0, 0, 0, 10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DataTemplate>

        <DataTemplate x:Key="DragCardVisualTemplate">
            <Image Source="{Binding ImagePath}" 
           Width="144" 
           Height="216"
           RenderOptions.BitmapScalingMode="HighQuality" />
        </DataTemplate>

        <DataTemplate x:Key="DragMeldVisualTemplate">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Image Source="{Binding ImagePath}" 
                               Width="144" 
                               Height="216"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="-100,0,0,0" />

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource PreviousData}}" Value="{x:Null}">
                                <Setter Property="Margin" Value="0"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

    </Window.Resources>

    <Grid x:Name="RootGrid" 
          AllowDrop="True" 
          DragOver="RootGridDragOver">

        <Image Source="/Resources/backgroundGame.jpg" Stretch="UniformToFill"/>

        <Viewbox Stretch="Uniform">

            <Grid x:Name="MainGrid" Width="1920" Height="1080"
                  GiveFeedback="MainGridGiveFeedback">

                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BackButton" Click="BackButtonClick" Margin="20"
                            Width="50" Height="50"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <TextBlock Text="&lt;"
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>
                    <Border Grid.Column="1" HorizontalAlignment="Center" Padding="15,5"
                                Background="#66000000" CornerRadius="5" Margin="0,0,130,45" Width="220">
                        <TextBlock Text="{Binding GameTimeDisplay}" FontSize="28" 
                                   FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,100,60,0"
                        Background="{StaticResource PrimaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}"
                                          ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="60" Height="60" CornerRadius="30"
                                BorderBrush="{StaticResource PrimaryTextBrush}"
                                BorderThickness="1">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Opponent.pathPhoto}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="{Binding Opponent.nickname}" VerticalAlignment="Center"
                                   Margin="15,0,0,0" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <ItemsControl HorizontalAlignment="Center"
                              VerticalAlignment="Top" 
                              Margin="0,130,0,0"
                              ItemTemplate="{StaticResource OpponentCardTemplate}"
                              ItemsSource="{Binding OpponentFaceDownCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl x:Name="OpponentMeldsItemsControl"
                              ItemsSource="{Binding OpponentMelds}"
                              ItemTemplate="{StaticResource MeldTemplate}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Margin="0,280,60,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Right"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="0,35,0,0">

                    <Image x:Name="DiscardPileImage"
                           Source="{Binding TopDiscardCard.ImagePath}"
                           Width="144" Height="216" 
                           Margin="0,0,20,0"
                           MouseLeftButtonDown="DiscardCardMouseLeftButtonDown"
                           MouseMove="DiscardCardMouseMove"
                           Cursor="Hand"/>

                    <Border x:Name="DropZone"
                            VerticalAlignment="Center"
                            Width="450" Height="250"
                            Background="#40FFFFFF" 
                            BorderBrush="White"
                            BorderThickness="2"
                            CornerRadius="10"
                            AllowDrop="True"
                            Drop="DropZoneDrop"
                            DragEnter="DropZoneDragEnter"
                            DragLeave="DropZoneDragLeave">

                        <Grid>
                            <TextBlock Text="{x:Static language:Lang.GameDropZone}" 
                                       Foreground="White"
                                       FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemporaryMeld.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding TemporaryMeld}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="100" Height="150" Margin="5">
                                            <Image Source="{Binding ImagePath}" ToolTip="{Binding Id}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TemporaryMeld.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Grid x:Name="StockPileGrid" 
                          Margin="20,0,0,0"
                          MouseLeftButtonDown="StockPileMouseLeftButtonDown"
                          Cursor="Hand"
                          AllowDrop="True"
                          DragEnter="StockPileDragEnter"
                          Drop="StockPileDrop">

                        <Image Source="/Resources/Assets/reverso.png" Width="144" Height="216"/>

                        <Border x:Name="BlinkingBorder"
                                BorderBrush="Yellow"
                                BorderThickness="4"
                                CornerRadius="12"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                <DropShadowEffect Color="Gold" BlurRadius="25" ShadowDepth="0"/>
                            </Border.Effect>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStockPileBlinking}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.2" To="1.0" 
                                                     Duration="0:0:0.6"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>

                </StackPanel>

                <Button Command="{Binding PassTurnCommand}"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="870,0,0,280" Width="180" Height="55"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <TextBlock Text="{x:Static language:Lang.GameToPass}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <ItemsControl x:Name="PlayerMeldsItemsControl"
                              ItemsSource="{Binding PlayerMelds}"
                              ItemTemplate="{StaticResource MeldTemplate}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Margin="60,0,0,250">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <ItemsControl x:Name="PlayerHandItemsControl"    
                              ItemsSource="{Binding PlayerHand}"
                              ItemTemplate="{StaticResource CardTemplate}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Bottom"
                              Margin="0,0,0,30"
                              AllowDrop="True"    
                              Drop="PlayerHandDrop">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="60,0,0,60"
                        Background="{StaticResource PrimaryBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="15,10">
                    <Border.Effect>
                        <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}"
                                          ShadowDepth="0" BlurRadius="20" Opacity="0.8"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="60" Height="60" CornerRadius="30"
                                BorderBrush="{StaticResource PrimaryTextBrush}"
                                BorderThickness="1">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding CurrentPlayer.pathPhoto}" Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <TextBlock Text="{Binding CurrentPlayer.nickname}" VerticalAlignment="Center"
                                   Margin="15,0,0,0" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="430,0,0,238">
                    <TextBlock Text="{Binding TurnStatusText}" FontSize="28"
                               FontWeight="Bold" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Viewbox>
        <Grid Background="#CC000000" Visibility="{Binding IsAFKWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="550" Height="320" 
                    CornerRadius="20" 
                    BorderThickness="3"
                    Padding="30"
                    Background="{StaticResource PrimaryBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}">

                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="10" Opacity="0.8"/>
                </Border.Effect>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{x:Static language:Lang.AFKNotice}" 
                               FontSize="28" 
                               FontWeight="ExtraBold" 
                               Foreground="#FFD700" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"
                               Margin="0,0,0,10">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Rectangle Height="2" Width="150" Fill="{StaticResource BorderBrush}" Margin="0,0,0,20" RadiusX="1" RadiusY="1"/>

                    <TextBlock Text="{x:Static language:Lang.AFKWarningMessage}" 
                               TextWrapping="Wrap" 
                               TextAlignment="Center" 
                               FontSize="18" 
                               LineHeight="24"
                               Foreground="{StaticResource PrimaryTextBrush}" 
                               Margin="0,0,0,30"/>

                    <Button Content="{x:Static language:Lang.GlobalAccept}" 
                            Command="{Binding AcceptAFKCommand}"
                            Width="160" Height="50" 
                            FontSize="18"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <Button.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.4"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>