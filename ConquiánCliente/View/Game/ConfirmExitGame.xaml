<Window x:Class="ConquiánCliente.View.Game.ConfirmExitGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Border Background="{StaticResource PrimaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                CornerRadius="10"
                Padding="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <StackPanel Width="360"
                        Orientation="Vertical">
                <TextBlock Text="{x:Static language:Lang.GameLeaveTheMatch}"
                           Style="{StaticResource TitleTextBlock}"
                           FontSize="26"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,30"/>

                <Button Width="200" Height="60"
                        Margin="0,0,0,10"
                        Click="SalirButtonClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ExitGameCommand}">
                    <TextBlock Text="{x:Static language:Lang.GameExit}"
                               FontSize="16" 
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <Button Width="200" Height="60"
                        Click="VolverAlJuegoButtonClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CloseDialogCommand}">
                    <TextBlock Text="{x:Static language:Lang.GameReturnToGame}"
                               FontSize="16" 
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>