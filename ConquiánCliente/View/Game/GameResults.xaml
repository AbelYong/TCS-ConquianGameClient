<Window x:Class="ConquiánCliente.View.Game.GameResults"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:ConquiánCliente.ViewModel.Game"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="{x:Static language:Lang.GameResultsTitle}"
        Height="1080" Width="1920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource PrimaryBackgroundBrush}" />
        <Image Source="/Resources/backgroundGame.jpg"
               Stretch="UniformToFill"
               Opacity="0.5" Cursor="Hand"/>

        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="800"
                Background="{StaticResource PrimaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                CornerRadius="10"
                Padding="40">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">

                <TextBlock Text="{Binding ResultTitle}"
                           Style="{StaticResource TitleTextBlock}"
                           FontSize="60"
                           Margin="0,0,0,40"/>

                <Grid HorizontalAlignment="Center" Margin="0,20,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="30,0">
                        <Border Grid.Row="0" Width="150" Height="150" CornerRadius="75" BorderBrush="#FFD700" BorderThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid>
                                <Ellipse Fill="Black" />

                                <Image Source="{Binding PlayerImage}" 
                                   Width="150" Height="150" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Stretch="UniformToFill">

                                    <Image.Clip>
                                        <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75" />
                                    </Image.Clip>
                                </Image>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding PlayerName}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="{x:Static language:Lang.GamePlayer}"
                                   FontSize="20"
                                   Foreground="LightGray"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding PlayerScore, StringFormat='Puntos ganados: {0}'}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="VS"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="25,0,25,-30"/>

                    <StackPanel Grid.Column="2" Orientation="Vertical" Margin="30,0">
                        <Border Grid.Row="0" Width="150" Height="150" CornerRadius="75" BorderBrush="#FFD700" BorderThickness="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid>
                                <Ellipse Fill="Black" />

                                <Image Source="{Binding OpponentImage}" 
                                   Width="150" Height="150" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Stretch="UniformToFill">

                                    <Image.Clip>
                                        <EllipseGeometry Center="75,75" RadiusX="75" RadiusY="75" />
                                    </Image.Clip>

                                </Image>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding OpponentName}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                        <TextBlock Text="{x:Static language:Lang.GameOpponent}"
                                   FontSize="20"
                                   Foreground="LightGray"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding OpponentScore, StringFormat='Puntos: {0}'}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Vertical" Margin="0,60,0,0" Width="350"
                            HorizontalAlignment="Center">

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Height="55"
                            FontSize="24"
                            FontWeight="Bold"
                            Margin="0,0,0,20"
                            Command="{Binding ReturnToMainMenuCommand}">
                        <TextBlock Text="{x:Static vm:GameResultsViewModel.ReturnButtonText}"
                                   FontSize="24" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                    </Button>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>