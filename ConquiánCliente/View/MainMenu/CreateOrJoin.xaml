<Window x:Class="ConquiánCliente.View.MainMenu.CreateOrJoin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConquiánCliente.View.MainMenu"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="CreateOrJoin" Height="400" Width="600"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid>
        <Border Background="{StaticResource PrimaryBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                CornerRadius="15">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <Grid>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Content="X"
                        Width="30"
                        Height="30"
                        FontWeight="Bold"
                        Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="{x:Static language:Lang.LobbyCreateRoom}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="300"
                            Height="60"
                            FontSize="24"
                            FontWeight="Bold"
                            Command="{Binding CreateRoomCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <TextBlock Text="{x:Static language:Lang.GlobalOr}"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,20"/>

                    <StackPanel>
                        <TextBlock Text="{x:Static language:Lang.LobbyJoinWithCode}"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="18"
                                   HorizontalAlignment="Center"/>

                        <Border Width="250"
                                Height="40"
                                CornerRadius="5"
                                BorderThickness="1"
                                BorderBrush="{StaticResource TextBoxBorderBrush}"
                                Background="Transparent"
                                Margin="0,10,0,10">

                            <Border.Effect>
                                <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                                  ShadowDepth="0" 
                                                  BlurRadius="10" 
                                                  Opacity="0.9" />
                            </Border.Effect>

                            <TextBox Padding="8"
                                     MaxLength="6"
                                     FontSize="20"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CaretBrush="{StaticResource PrimaryTextBrush}"
                                     TextAlignment="Center"
                                     Text="{Binding RoomCode, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>

                        <Button Content="{x:Static language:Lang.LobbyJoinRoom}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="250"
                                Height="50"
                                FontSize="20"
                                FontWeight="Bold"
                                Command="{Binding JoinRoomCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>