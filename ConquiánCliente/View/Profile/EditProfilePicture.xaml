<Window x:Class="ConquiánCliente.View.Profile.EditProfilePicture"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConquiánCliente.View.Profile"
        xmlns:viewModel="clr-namespace:ConquiánCliente.ViewModel.Profile"
        xmlns:converter="clr-namespace:ConquiánCliente.ViewModel"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="{x:Static language:Lang.ProfileChange}" Height="1080" Width="1920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.DataContext>
        <viewModel:EditProfilePictureViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converter:ImagePathToBooleanConverter x:Key="ImagePathToBooleanConverter"/>

        <Style x:Key="AvatarBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="{Binding Color, Source={StaticResource PrimaryButtonBrush}}" 
                                      ShadowDepth="0" 
                                      BlurRadius="10" 
                                      Opacity="0.9" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="BorderBrush" Value="Gray"/>
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource PrimaryButtonBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="20" 
                                              Opacity="1" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="AvatarButtonStyle" TargetType="Button" BasedOn="{StaticResource NoFocusButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBackgroundBrush}" />
        <Image Source="/Resources/background.jpg" 
               Stretch="UniformToFill" 
               Opacity="0.5"/>

        <Border BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                Background="{StaticResource PrimaryBackgroundBrush}"
                CornerRadius="10"
                Padding="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="600">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="{x:Static language:Lang.ProfileChange}" 
                           Style="{StaticResource TitleTextBlock}" 
                           Margin="0,0,0,30"/>

                <WrapPanel HorizontalAlignment="Center" MaxWidth="400">

                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar01.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/avatar01.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar02.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/avatar02.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar03.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/avatar03.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar04.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/avatar04.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar05.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/avatar05.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                    <Button Command="{Binding SelectImageCommand}" CommandParameter="/Resources/imageProfile/avatar06.JPG" Style="{StaticResource AvatarButtonStyle}">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource ImagePathToBooleanConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="CurrentProfilePicturePath"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                        <Border Style="{StaticResource AvatarBorderStyle}">
                            <Image Source="/Resources/imageProfile/default.JPG" Stretch="UniformToFill"/>
                        </Border>
                    </Button>
                </WrapPanel>

                <Button Command="{Binding ChangeProfilePictureCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,30,0,10" Width="165" Height="40">
                    <TextBlock Text="{x:Static language:Lang.ProfileChange}" 
                               FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <Button Command="{Binding CloseWindowCommand}" 
                        Content="{x:Static language:Lang.GlobalBack}"
                        Style="{StaticResource NoFocusButtonStyle}"
                        Foreground="{StaticResource ForgotPasswordTextBrush}" 
                        FontSize="14" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>