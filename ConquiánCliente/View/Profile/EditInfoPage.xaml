<Page x:Class="ConquiánCliente.View.Profile.EditInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:ConquiánCliente.View"
      xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
      xmlns:viewModel="clr-namespace:ConquiánCliente.ViewModel.Profile"
      mc:Ignorable="d"
      Background="Transparent">

    <Grid>
        <Border BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="2"
                Background="{StaticResource PrimaryBackgroundBrush}"
                CornerRadius="10"
                Padding="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="600" MinWidth="550">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <TextBlock Text="{x:Static language:Lang.EditDataEdit}" 
                           Style="{StaticResource TitleTextBlock}" 
                           Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="{x:Static language:Lang.GlobalNickname}" FontWeight="Bold" Margin="0,5,20,5" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <Border Grid.Row="0" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            BorderBrush="{StaticResource TextBoxBorderBrush}" 
                            Margin="0,5"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding Player.nickname}" 
                                 MaxLength="15"
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Label Grid.Row="1" Grid.Column="0" Content="{x:Static language:Lang.GlobalName}" FontWeight="Bold" Margin="0,5,20,5" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <Border Grid.Row="1" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            BorderBrush="{StaticResource TextBoxBorderBrush}" 
                            Margin="0,5"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding Player.name}" 
                                 MaxLength="25"
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Label Grid.Row="2" Grid.Column="0" Content="{x:Static language:Lang.GlobalLastName}" FontWeight="Bold" Margin="0,5,20,5" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <Border Grid.Row="2" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            BorderBrush="{StaticResource TextBoxBorderBrush}" 
                            Margin="0,5"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding Player.lastName}" 
                                 MaxLength="50"
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Label Grid.Row="3" Grid.Column="0" Content="{x:Static language:Lang.GlobalEmail}" FontWeight="Bold" Margin="0,5,20,5" VerticalAlignment="Center" Foreground="{StaticResource PrimaryTextBrush}"/>
                    <Border Grid.Row="3" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            Margin="0,5"
                            BorderBrush="{StaticResource TextBoxBorderBrush}"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding Player.email}" 
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent" 
                                 IsReadOnly="True" 
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Image Grid.Row="5" Grid.Column="0" Source="/Resources/facebook.png" Width="24" Height="24" Margin="0,5,20,5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Border Grid.Row="5" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            BorderBrush="{StaticResource TextBoxBorderBrush}" 
                            Margin="0,5"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding FacebookLink}" 
                                 MaxLength="25"
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>

                    <Image Grid.Row="6" Grid.Column="0" Source="/Resources/instagram.png" Width="24" Height="24" Margin="0,5,20,5" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Border Grid.Row="6" Grid.Column="1" 
                            CornerRadius="5" 
                            BorderThickness="1" 
                            BorderBrush="{StaticResource TextBoxBorderBrush}" 
                            Margin="0,5"
                            Background="Transparent">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                              ShadowDepth="0" 
                                              BlurRadius="10" 
                                              Opacity="0.9" />
                        </Border.Effect>
                        <TextBox Text="{Binding InstagramLink}" 
                                 MaxLength="25"
                                 Padding="8" 
                                 FontSize="16" 
                                 BorderThickness="0" 
                                 Background="Transparent"
                                 Foreground="{StaticResource PrimaryTextBrush}"
                                 CaretBrush="{StaticResource PrimaryTextBrush}"/>
                    </Border>
                </Grid>

                <Button Margin="0,30,0,0" Style="{StaticResource PrimaryButtonStyle}" Width="165" Height="40"
                        Command="{Binding SaveChangesCommand}">
                    <TextBlock Text="{x:Static language:Lang.EditDataEdit}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center" />
                </Button>

                <Button Margin="0,15,0,0" Style="{StaticResource PrimaryButtonStyle}" Width="165" Height="40"
                        Command="{Binding NavigateToChangePasswordCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Page}}">
                    <TextBlock Text="{x:Static language:Lang.UserProfileChangePassword}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center" />
                </Button>
                
                <Button Style="{StaticResource NoFocusButtonStyle}" 
                        Margin="0,15,0,0"
                        Command="{Binding CancelCommand}">
                    <TextBlock Text="{x:Static language:Lang.GlobalBack}"
                               Foreground="{StaticResource ForgotPasswordTextBrush}" 
                               FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>