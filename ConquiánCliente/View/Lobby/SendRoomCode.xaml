<Window x:Class="ConquiánCliente.View.Lobby.SendRoomCode"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConquiánCliente.View.Authentication.PasswordRecovery"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="{x:Static language:Lang.LobbySendRoomCode}" 
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        WindowStartupLocation="CenterOwner" 
        SizeToContent="WidthAndHeight">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Border BorderBrush="{StaticResource BorderBrush}" 
              BorderThickness="2" 
              Background="{StaticResource PrimaryBackgroundBrush}" 
              CornerRadius="10" 
              Padding="35" 
              HorizontalAlignment="Center" 
              VerticalAlignment="Center"
              MaxWidth="600" Width="444">

            <Border.Effect>
                <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                  ShadowDepth="0" 
                                  BlurRadius="20" 
                                  Opacity="1"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical" IsEnabled="{Binding IsControlEnabled}">
                <TextBlock Text="{x:Static language:Lang.LobbySendRoomCode}" 
                           Style="{StaticResource TitleTextBlock}"
                           Margin="0,0,0,30"/>

                <TextBlock Text="{x:Static language:Lang.GlobalEmail}" 
                           FontSize="16" 
                           Margin="0,0,0,8"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Left"/>

                <Border CornerRadius="5" 
                        BorderThickness="1" 
                        BorderBrush="{StaticResource TextBoxBorderBrush}"
                        Background="Transparent">

                    <Border.Effect>
                        <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                          ShadowDepth="0" 
                                          BlurRadius="10" 
                                          Opacity="0.9" />
                    </Border.Effect>

                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" 
                             MaxLength="45"
                             Padding="8" 
                             FontSize="16"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CaretBrush="{StaticResource PrimaryTextBrush}"/>
                </Border>

                <Button Margin="0,30,0,10" Height="43" Width="168" 
                        Command="{Binding SendCommand}"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <TextBlock Text="{x:Static language:Lang.GlobalAccept}" 
                               FontSize="16" 
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Button>

                <Button Style="{StaticResource NoFocusButtonStyle}" Margin="0,15,0,0"
                        Command="{Binding BackCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBlock Text="{x:Static language:Lang.GlobalBack}"
                               Foreground="{StaticResource ForgotPasswordTextBrush}"
                               FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <TextBlock Text="{x:Static language:Lang.GlobalLoading}"
                   Style="{StaticResource TitleTextBlock}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                   Margin="0,30,0,0"/>
    </Grid>
</Window>