<Window x:Class="ConquiánCliente.View.Lobby.LobbyGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:language="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="{x:Static language:Lang.Lobby}"
        Height="1080" Width="1920"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="KickButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="5" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LobbyHostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Effect" Value="{x:Null}"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBackgroundBrush}" />
        <Image Source="/Resources/background.jpg" 
               Stretch="UniformToFill"
               Opacity="0.5"/>
        <Grid>
            <Button HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="20" Width="50" Height="50"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding GoBackCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                <TextBlock Text="&lt;" 
                           FontSize="24" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Button>

            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="20">
                <TextBlock Text="{x:Static language:Lang.LobbyRoomCode}"
                           FontSize="22" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding RoomCode}" FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Right" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Vertical"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="40,100,0,0"
                        Width="450">
                <ItemsControl ItemsSource="{Binding Players}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,20" 
                                    BorderBrush="{StaticResource BorderBrush}" 
                                    BorderThickness="2" 
                                    Background="{StaticResource PrimaryBackgroundBrush}" 
                                    CornerRadius="10" 
                                    Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                                      ShadowDepth="0" 
                                                      BlurRadius="20" 
                                                      Opacity="0.8"/>
                                </Border.Effect>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="50" Height="50" CornerRadius="25"
                                            BorderBrush="{StaticResource PrimaryTextBrush}"
                                            BorderThickness="1">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ProfileImagePath}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>

                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding DisplayName}"
                                               VerticalAlignment="Center"
                                               Margin="15,0,0,0"
                                               FontSize="20"
                                               Foreground="{StaticResource PrimaryTextBrush}"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Button Grid.Column="2" 
                                            Content="X"
                                            Width="35" Height="35"
                                            Style="{StaticResource KickButtonStyle}"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.KickPlayerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"
                                            Visibility="{Binding DataContext.IsHost, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,60,0,0">
                <TextBlock Text="{x:Static language:Lang.Lobby}"
                           Style="{StaticResource TitleTextBlock}"
                           FontSize="70"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding PlayerCountText}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="422">
                <Button Width="388" Height="62" Margin="0,20,0,0"
                        Style="{StaticResource LobbyHostButtonStyle}"
                        IsEnabled="{Binding IsHost}"
                        Command="{Binding StartGameCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <TextBlock Text="{x:Static language:Lang.LobbyStartGame}"
                               FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button Width="60" Height="50" 
                            Style="{StaticResource LobbyHostButtonStyle}" 
                            Command="{Binding PreviousGameTypeCommand}"
                            IsEnabled="{Binding IsHost}">
                        <TextBlock Text="&lt;" FontSize="26" FontWeight="Bold"/>
                    </Button>

                    <Border Width="200" Height="50" Margin="10,0,10,0" 
                            Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="5">
                        <Border.Effect>
                            <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                                              ShadowDepth="0" BlurRadius="10" Opacity="1"/>
                        </Border.Effect>
                        <TextBlock Text="{Binding SelectedGameType}"
                                   FontSize="26" FontWeight="Bold" 
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Button Width="60" Height="50" 
                            Style="{StaticResource LobbyHostButtonStyle}" 
                            Command="{Binding NextGameTypeCommand}"
                            IsEnabled="{Binding IsHost}">
                        <TextBlock Text="&gt;" FontSize="26" FontWeight="Bold"/>
                    </Button>
                </StackPanel>

                <Button Width="388" Height="62" Margin="0,30,0,0" 
                        Style="{StaticResource LobbyHostButtonStyle}"
                        IsEnabled="{Binding IsHost}"
                        Command="{Binding ShowInviteFriendsCommand}">
                    <TextBlock Text="{x:Static language:Lang.GlobalInvite}"
                               FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>

            <Grid HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Margin="20,0,0,48" Width="500" Height="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Background="#66000000" Padding="5">
                    <ListBox x:Name="ltBxChat"
                             ItemsSource="{Binding ChatMessages}" 
                             Background="Transparent" 
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Style="{StaticResource ChatListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock TextWrapping="Wrap" Margin="0,2">
                                    <Run Text="{Binding Nickname}" FontWeight="Bold" Foreground="#FFD700"/> 
                                    <Run Text=": " Foreground="White"/>
                                    <Run Text="{Binding Message}" Foreground="White"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>

                <TextBlock Grid.Row="1"
                           Text="{Binding CooldownText}"
                           Visibility="{Binding IsCooldownVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Foreground="#FF5252"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,2"
                           TextWrapping="Wrap"
                           TextAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Color="Black" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Grid.Row="2" CornerRadius="5" BorderThickness="1" 
                        BorderBrush="{StaticResource TextBoxBorderBrush}"
                        Background="Transparent" Margin="0,5,0,0">
                    <Border.Effect>
                        <DropShadowEffect Color="{Binding Color, Source={StaticResource TextBoxBorderBrush}}" 
                                          ShadowDepth="0" BlurRadius="10" Opacity="0.9" />
                    </Border.Effect>
                    <TextBox Height="40" FontSize="16" VerticalContentAlignment="Center"
                             Text="{Binding CurrentMessage, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource PrimaryTextBrush}"
                             CaretBrush="{StaticResource PrimaryTextBrush}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>