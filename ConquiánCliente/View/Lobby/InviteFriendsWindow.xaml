<Window x:Class="ConquiánCliente.View.Lobby.InviteFriendsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lang="clr-namespace:ConquiánCliente.Properties.Langs"
        mc:Ignorable="d"
        Title="{x:Static lang:Lang.GlobalInvite}" Height="520" Width="428" 
        WindowStartupLocation="CenterOwner" 
        ShowInTaskbar="False"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="LobbyHostButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Effect" Value="{x:Null}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PrimaryBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="2"
            CornerRadius="10"
            Padding="15">

        <Border.Effect>
            <DropShadowEffect Color="{Binding Color, Source={StaticResource BorderBrush}}" 
                              ShadowDepth="0" 
                              BlurRadius="20" 
                              Opacity="1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{x:Static lang:Lang.GlobalInvite}"
                       Style="{StaticResource TitleTextBlock}"
                       Margin="0,0,0,15"/>

            <Button Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-5,-5,0"
                    Content="X"
                    Width="30"
                    Height="30"
                    FontWeight="Bold"
                    Click="CloseButton_Click"/>

            <ListView Grid.Row="1" ItemsSource="{Binding FriendsList}" Background="Transparent" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="350" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="40" Height="40" CornerRadius="20" Grid.Column="0" ClipToBounds="True"
                                    BorderBrush="{StaticResource PrimaryTextBrush}" BorderThickness="1">
                                <Image Source="{Binding ProfileImagePath}" Stretch="UniformToFill" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding Nickname}" Foreground="{StaticResource PrimaryTextBrush}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"/>
                            </StackPanel>

                            <Button Grid.Column="2" 
                                    Command="{Binding DataContext.InviteFriendCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"
                                    IsEnabled="{Binding IsOnline}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="100">
                                <TextBlock Text="{x:Static lang:Lang.GlobalInvite}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Grid.Row="2"
                    Style="{StaticResource PrimaryButtonStyle}" 
                    HorizontalAlignment="Center"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Command="{Binding SendRoomCodeCommand}"
                    Width="200" 
                    Height="50"
                    Margin="0,15,0,0">
                <TextBlock Text="{x:Static lang:Lang.LobbySendRoomCode}"
                           FontSize="16"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Button>
        </Grid>
    </Border>
</Window>